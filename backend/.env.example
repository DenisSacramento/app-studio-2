NODE_ENV=development
PORT=5000
HOST=0.0.0.0
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_studio?schema=public"
JWT_SECRET=troque-por-uma-chave-segura
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=troque-por-outra-chave-segura
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
CORS_ORIGINS=https://SEU_FRONTEND_PUBLICO.com,https://app.expo.dev
EXPO_PUBLIC_API_URL=https://app-studio-2.onrender.com/api

# SMTP (obrigatório em produção para recuperação de senha)
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=usuario-smtp
SMTP_PASSWORD=senha-smtp
SMTP_FROM="Studio Karine <no-reply@studio-karine.com>"
SMTP_SECURE=false

# Recuperação de senha
RESET_PASSWORD_TOKEN_TTL_MINUTES=20
# URL da tela de redefinição (web/deep-link), ex: https://seuapp.com/reset-password
RESET_PASSWORD_URL=
